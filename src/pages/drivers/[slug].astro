---
import Layout from "../../layouts/Layout.astro";
import siteContent from "../../data/siteContent.json";
import Breadcrumbs from "../../components/SEO/Breadcrumbs.astro";
import { Star, Clock, Languages, ShieldCheck, Car, MessageCircle, Download, MapPin } from "lucide-react";

function toSlug(name: string) {
  return name
    .toLowerCase()
    .replace(/\s+/g, "-")
    .replace(/[^a-z0-9-]/g, "");
}

export function getStaticPaths() {
  const toSlug = (name: string) =>
    name.toLowerCase().replace(/\s+/g, "-").replace(/[^a-z0-9-]/g, "");

  return siteContent.drivers.map((driver) => ({
    params: { slug: toSlug(driver.name) },
    props: { driver },
  }));
}

const { driver } = Astro.props;
const slug = toSlug(driver.name);

const site = "https://kalidasstravels.in";
const profileUrl = `${site}/drivers/${slug}`;
// Driver shares this — written in their voice
const waDriverShareText = encodeURIComponent(
  `Hi! 👋 I'm *${driver.name}*, a professional driver at *Kalidass Travels*.\n\n` +
  `⭐ *${driver.rating}* Rating  |  ${driver.trips} Trips  |  ${driver.experience}\n` +
  `✅ PVC Police Verified\n` +
  `🚗 Specialty: ${driver.specialty}\n\n` +
  `Book your next trip with me 👇\n` +
  `${profileUrl}`
);

// Customer already on the page — booking this driver
const bookingUrl = `/?driver=${encodeURIComponent(driver.name)}#booking-panel`;

const storyCardUrl = `/driver-cards/${slug}`;

// The og:image must be an absolute image URL so WhatsApp shows the driver photo on link preview
const ogImageUrl = `${site}${driver.image}`;

const breadcrumbItems = [
  { name: "Home", item: "/" },
  { name: "Drivers", item: "/drivers" },
  { name: driver.name, item: `/drivers/${slug}` },
];
---

<Layout
  title={`${driver.name} – Professional Driver | Kalidass Travels`}
  description={`${driver.name} is a PVC verified driver with ${driver.experience} and ${driver.trips} trips, specialising in ${driver.specialty}. Book now via Kalidass Travels.`}
  image={ogImageUrl}
  ogImage={ogImageUrl}
  type="profile"
>
  <Breadcrumbs items={breadcrumbItems} />

  <main class="bg-slate-50 min-h-screen pb-24 pt-6">
    <div class="max-w-lg mx-auto px-4 flex flex-col gap-4">

      <!-- ── PROFILE CARD (what customers see) ── -->
      <div class="bg-white rounded-3xl shadow-md overflow-hidden border border-slate-200">

        <!-- Photo with overlay -->
        <div class="relative">
          <img
            src={driver.image}
            alt={driver.alt || driver.name}
            class="w-full h-72 sm:h-96 object-cover object-top"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent"></div>

          <!-- Tag pill -->
          <div class="absolute top-4 left-4 inline-flex items-center gap-1.5 bg-white/15 backdrop-blur-sm border border-white/30 rounded-full px-3 py-1">
            <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
            <span class="text-white text-xs font-bold">{driver.tag}</span>
          </div>

          <!-- Rating pill -->
          <div class="absolute top-4 right-4 flex items-center gap-1.5 bg-amber-400 text-white px-3 py-1.5 rounded-full shadow-lg">
            <Star className="w-4 h-4 fill-current" />
            <span class="font-black text-sm">{driver.rating}</span>
          </div>

          <!-- Name block -->
          <div class="absolute bottom-0 left-0 p-5">
            <h1 class="text-3xl font-extrabold text-white leading-tight drop-shadow-sm">{driver.name}</h1>
            <p class="text-white/80 text-sm mt-0.5">{driver.specialty}</p>
          </div>
        </div>

        <!-- Stats strip -->
        <div class="grid grid-cols-3 divide-x divide-slate-100 border-b border-slate-100 bg-slate-50">
          <div class="flex flex-col items-center py-3 gap-0.5">
            <span class="text-xl font-black text-indigo-600">{driver.rating}</span>
            <span class="text-[10px] text-slate-500 font-semibold uppercase tracking-wide">Rating</span>
          </div>
          <div class="flex flex-col items-center py-3 gap-0.5">
            <span class="text-xl font-black text-indigo-600">{driver.trips}</span>
            <span class="text-[10px] text-slate-500 font-semibold uppercase tracking-wide">Trips</span>
          </div>
          <div class="flex flex-col items-center py-3 gap-0.5">
            <span class="text-xl font-black text-indigo-600">{driver.reviews}</span>
            <span class="text-[10px] text-slate-500 font-semibold uppercase tracking-wide">Reviews</span>
          </div>
        </div>

        <!-- Details -->
        <div class="p-5 space-y-3">
          <div class="inline-flex items-center gap-2 bg-green-50 border border-green-200 rounded-xl px-3 py-1.5">
            <ShieldCheck className="w-4 h-4 text-green-600" />
            <span class="text-xs font-bold text-green-700">PVC Police Verified</span>
          </div>

          <div class="grid grid-cols-1 gap-2.5 pt-1">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-xl bg-indigo-50 flex items-center justify-center shrink-0">
                <Clock className="w-4 h-4 text-indigo-500" />
              </div>
              <div>
                <p class="text-[10px] text-slate-400 uppercase tracking-wide font-bold">Experience</p>
                <p class="text-sm font-semibold text-slate-800">{driver.experience}</p>
              </div>
            </div>

            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-xl bg-indigo-50 flex items-center justify-center shrink-0">
                <Languages className="w-4 h-4 text-indigo-500" />
              </div>
              <div>
                <p class="text-[10px] text-slate-400 uppercase tracking-wide font-bold">Languages</p>
                <p class="text-sm font-semibold text-slate-800">{driver.languages}</p>
              </div>
            </div>

            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-xl bg-indigo-50 flex items-center justify-center shrink-0">
                <Car className="w-4 h-4 text-indigo-500" />
              </div>
              <div>
                <p class="text-[10px] text-slate-400 uppercase tracking-wide font-bold">Specialty</p>
                <p class="text-sm font-semibold text-slate-800">{driver.specialty}</p>
              </div>
            </div>

            {driver.crossing_border && (
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-xl bg-amber-50 flex items-center justify-center shrink-0">
                  <MapPin className="w-4 h-4 text-amber-500" />
                </div>
                <div>
                  <p class="text-[10px] text-slate-400 uppercase tracking-wide font-bold">Clearance</p>
                  <p class="text-sm font-semibold text-slate-800">Cross-border driving approved</p>
                </div>
              </div>
            )}
          </div>
        </div>

        <!-- ── CUSTOMER CTA ── -->
        <div class="px-5 pb-5">
          <a
            href={bookingUrl}
            class="flex items-center justify-center gap-3 w-full bg-[#25D366] hover:bg-[#1ebe5d] active:scale-[0.98] text-white font-black py-4 rounded-2xl transition-all text-base shadow-lg shadow-green-200"
          >
            <MessageCircle className="w-5 h-5" />
            Book a Trip with {driver.name}
          </a>
          <p class="text-center text-[11px] text-slate-400 mt-2">
            Enter your trip details → get instant estimate → confirm via WhatsApp
          </p>
        </div>
      </div>

      <!-- Back link -->
      <a href="/drivers" class="text-center text-sm text-indigo-600 hover:text-indigo-700 font-semibold py-2">
        ← View All Drivers
      </a>

      <!-- Staff-only sharing tools — hidden behind a barely-visible toggle -->
      <details class="text-center pb-6">
        <summary class="text-[11px] text-slate-300 hover:text-slate-400 cursor-pointer select-none list-none inline">
          • • •
        </summary>
        <div class="mt-3 flex justify-center gap-3 flex-wrap">
          <a
            href={`https://wa.me/?text=${waDriverShareText}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-[#25D366] hover:bg-[#1ebe5d] text-white text-xs font-semibold px-4 py-2 rounded-full transition-colors"
          >
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Share in Chat
          </a>
          <a
            href={storyCardUrl}
            class="inline-flex items-center gap-2 bg-slate-200 hover:bg-slate-300 text-slate-700 text-xs font-semibold px-4 py-2 rounded-full transition-colors"
          >
            <Download className="w-3.5 h-3.5" />
            Story Card
          </a>
        </div>
      </details>

    </div>
  </main>
</Layout>
