---
import Layout from "../layouts/Layout.astro";
import Breadcrumbs from "../components/SEO/Breadcrumbs.astro";
import tariffConfig from "../data/tariff_config.json";

const breadcrumbItems = [
  { name: "Home", item: "/" },
  { name: "Tariff", item: "/tariff" },
];

const vehicles = Object.entries(tariffConfig.vehicles);


const vehicleCapacity: Record<string, string> = {
  "Swift Dzire":     "4 Pax",
  "Toyota Etios":    "4 Pax",
  "Innova":          "6 Pax",
  "Innova Crysta":   "7 Pax",
  "Tempo Traveller": "12 Pax",
};
---

<Layout
  title="Taxi Tariff & Pricing | Kalidass Travels"
  description="Transparent per-km taxi rates for outstation and local trips. Swift Dzire, Innova, Tempo Traveller — no hidden charges."
  keywords="taxi tariff Chennai, cab rates per km, outstation taxi price, innova taxi fare, swift dzire price per km"
>
  <Breadcrumbs items={breadcrumbItems} />

  <div class="bg-slate-50 min-h-screen pt-12 pb-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Header -->
      <div class="text-center mb-10">
        <h1 class="text-4xl font-bold text-slate-900 mb-3">Taxi Tariff</h1>
        <p class="text-lg text-slate-600 max-w-xl mx-auto">
          Fixed, transparent rates. No surge pricing. No hidden charges.
        </p>
      </div>

      <!-- Section 1: Outstation Rates -->
      <div class="mb-10">
        <h2 class="text-xl font-bold text-slate-800 mb-4">Outstation Rates (Per KM)</h2>
        <div class="overflow-x-auto rounded-2xl shadow-sm border border-slate-200">
          <table class="w-full text-sm text-left bg-white">
            <thead class="bg-slate-900 text-white text-xs uppercase tracking-wider">
              <tr>
                <th class="px-5 py-4 sticky left-0 z-10 bg-slate-900">Vehicle</th>
                <th class="px-5 py-4">Capacity</th>
                <th class="px-5 py-4">One Way (₹/km)</th>
                <th class="px-5 py-4">Round Trip (₹/km)</th>
                <th class="px-5 py-4">Min KM / Day</th>
                <th class="px-5 py-4">Driver Bata</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              {vehicles.map(([name, v], i) => (
                <tr class={i % 2 === 0 ? "bg-white" : "bg-slate-50"}>
                  <td class={`px-5 py-4 font-semibold text-slate-900 sticky left-0 z-10 ${i % 2 === 0 ? "bg-white" : "bg-slate-50"}`}>{name}</td>
                  <td class="px-5 py-4 text-slate-600">{vehicleCapacity[name]}</td>
                  <td class="px-5 py-4 font-bold text-red-700">₹{v.one_way_rate}</td>
                  <td class="px-5 py-4 font-bold text-indigo-700">₹{v.round_trip_rate}</td>
                  <td class="px-5 py-4 text-slate-600">{v.min_km_per_day} km</td>
                  <td class="px-5 py-4 text-slate-600">₹{v.driver_bata} / day</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="text-xs text-slate-500 mt-3">
          * One Way minimum: 130 km (except Tempo Traveller: 250 km). Driver Bata includes food & stay.
        </p>
      </div>

      <!-- Section 2: Local Package Rates -->
      <div class="mb-10">
        <h2 class="text-xl font-bold text-slate-800 mb-4">Local City Packages</h2>
        <div class="overflow-x-auto rounded-2xl shadow-sm border border-slate-200">
          <table class="w-full text-sm text-left bg-white">
            <thead class="bg-slate-900 text-white text-xs uppercase tracking-wider">
              <tr>
                <th class="px-5 py-4 sticky left-0 z-10 bg-slate-900">Vehicle</th>
                <th class="px-5 py-4">Capacity</th>
                <th class="px-5 py-4">8 Hrs / 80 KM</th>
                <th class="px-5 py-4">12 Hrs / 120 KM</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              {vehicles.map(([name, v], i) => (
                <tr class={i % 2 === 0 ? "bg-white" : "bg-slate-50"}>
                  <td class={`px-5 py-4 font-semibold text-slate-900 sticky left-0 z-10 ${i % 2 === 0 ? "bg-white" : "bg-slate-50"}`}>{name}</td>
                  <td class="px-5 py-4 text-slate-600">{vehicleCapacity[name]}</td>
                  <td class="px-5 py-4 font-bold text-emerald-700">₹{v.local_8hr_pkg.toLocaleString("en-IN")}</td>
                  <td class="px-5 py-4 font-bold text-emerald-700">₹{v.local_12hr_pkg.toLocaleString("en-IN")}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="text-xs text-slate-500 mt-3">
          * Extra KM and extra hours charged additionally. Fuel included. Tolls & parking extra.
        </p>
      </div>

      <!-- Inclusions / Exclusions -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-10">
        <div class="bg-emerald-50 border border-emerald-200 rounded-2xl p-5">
          <h3 class="font-bold text-emerald-800 mb-3">Inclusions</h3>
          <ul class="space-y-2 text-sm text-emerald-800">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Fuel charges
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Driver service & bata
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              GST
            </li>
          </ul>
        </div>
        <div class="bg-red-50 border border-red-200 rounded-2xl p-5">
          <h3 class="font-bold text-red-800 mb-3">Exclusions</h3>
          <ul class="space-y-2 text-sm text-red-800">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              Toll charges (as per actual)
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              Parking fees
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              Interstate permit (if applicable)
            </li>
          </ul>
        </div>
      </div>

      <!-- CTA -->
      <div class="text-center">
        <p class="text-slate-600 mb-4 text-sm">Want an exact estimate for your trip?</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href="/calculator/"
            class="inline-flex items-center justify-center gap-2 bg-red-700 hover:bg-red-800 text-white font-semibold px-8 py-3 rounded-xl transition-all shadow-md"
          >
            Use the Calculator
          </a>
          <a
            href="https://wa.me/919092303060?text=Hi%2C%20I%27d%20like%20to%20book%20a%20cab."
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 bg-green-600 hover:bg-green-700 text-white font-semibold px-8 py-3 rounded-xl transition-all shadow-md"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
            Book on WhatsApp
          </a>
        </div>
      </div>

    </div>
  </div>
</Layout>
