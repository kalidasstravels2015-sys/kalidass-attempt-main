---
import siteContent from "../../data/siteContent.json";

export function getStaticPaths() {
  const toSlug = (name: string) =>
    name.toLowerCase().replace(/\s+/g, "-").replace(/[^a-z0-9-]/g, "");

  return siteContent.drivers.map((driver) => ({
    params: { slug: toSlug(driver.name) },
    props: { driver },
  }));
}

const { driver } = Astro.props;

function starsString(rating: string) {
  const n = Math.round(parseFloat(rating));
  return "★".repeat(n) + "☆".repeat(Math.max(0, 5 - n));
}

const stars = starsString(driver.rating);
const site = "https://kalidasstravels.in";

function toSlug(name: string) {
  return name.toLowerCase().replace(/\s+/g, "-").replace(/[^a-z0-9-]/g, "");
}

const slug = toSlug(driver.name);
const profileUrl = `${site}/drivers/${slug}`;
const phone = siteContent.hero.phone.replace(/\D/g, "");

const waBookText = encodeURIComponent(
  `Hi, I want to book *${driver.name}* for my trip.\n\nDriver Profile: ${profileUrl}\n\nPlease share availability.`
);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{driver.name} – Story Card | Kalidass Travels</title>
  <meta name="robots" content="noindex" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: #1e293b;
      display: flex;
      flex-direction: column;
      align-items: center;
      min-height: 100vh;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      padding: 16px;
      gap: 16px;
    }

    /* The card itself — 9:16 portrait */
    #story-card {
      width: 360px;
      height: 640px;
      border-radius: 20px;
      overflow: hidden;
      position: relative;
      flex-shrink: 0;
      box-shadow: 0 25px 60px rgba(0,0,0,0.5);
      background: #0f172a;
    }

    .card-photo {
      width: 100%;
      height: 370px;
      object-fit: cover;
      object-position: top center;
      display: block;
    }

    .card-photo-fade {
      position: absolute;
      top: 310px;
      left: 0;
      right: 0;
      height: 80px;
      background: linear-gradient(to bottom, transparent, #0f172a);
    }

    .card-content {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 14px 18px 18px;
      background: #0f172a;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .card-name-row {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 8px;
    }

    .card-name {
      font-size: 22px;
      font-weight: 800;
      color: #ffffff;
      line-height: 1.15;
      letter-spacing: -0.3px;
    }

    .card-specialty {
      font-size: 11px;
      color: #94a3b8;
      margin-top: 2px;
    }

    .card-rating-pill {
      background: #fef3c7;
      border-radius: 10px;
      padding: 6px 10px;
      display: flex;
      flex-direction: column;
      align-items: center;
      flex-shrink: 0;
      min-width: 52px;
    }

    .card-rating-num {
      font-size: 18px;
      font-weight: 800;
      color: #92400e;
      line-height: 1;
    }

    .card-rating-stars {
      font-size: 8px;
      color: #d97706;
      letter-spacing: 1px;
    }

    .card-badges {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }

    .badge-verified {
      background: #14532d;
      color: #4ade80;
      font-size: 10px;
      font-weight: 700;
      padding: 4px 10px;
      border-radius: 20px;
    }

    .badge-trips {
      background: #1e3a8a;
      color: #93c5fd;
      font-size: 10px;
      font-weight: 700;
      padding: 4px 10px;
      border-radius: 20px;
    }

    .card-stats {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .card-stat {
      font-size: 11px;
      color: #cbd5e1;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .card-dot {
      width: 5px;
      height: 5px;
      background: #6366f1;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .card-footer {
      border-top: 1px solid #1e293b;
      padding-top: 10px;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .card-brand {
      font-size: 13px;
      font-weight: 800;
      color: #ffffff;
      letter-spacing: 1.5px;
    }

    .card-contact {
      font-size: 10px;
      color: #64748b;
    }

    /* Action buttons below the card */
    .actions {
      display: flex;
      flex-direction: column;
      gap: 10px;
      width: 360px;
    }

    .btn-download {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      width: 100%;
      padding: 15px;
      background: #4f46e5;
      color: white;
      font-size: 15px;
      font-weight: 700;
      border: none;
      border-radius: 14px;
      cursor: pointer;
      transition: background 0.2s;
    }

    .btn-download:hover { background: #4338ca; }
    .btn-download:disabled { background: #374151; cursor: not-allowed; }

    .btn-whatsapp {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      width: 100%;
      padding: 15px;
      background: #25D366;
      color: white;
      font-size: 15px;
      font-weight: 700;
      text-decoration: none;
      border-radius: 14px;
      transition: background 0.2s;
    }
    .btn-whatsapp:hover { background: #1ebe5d; }

    .btn-back {
      display: block;
      text-align: center;
      color: #94a3b8;
      font-size: 13px;
      text-decoration: none;
      padding: 8px;
    }

    .hint {
      color: #64748b;
      font-size: 12px;
      text-align: center;
      line-height: 1.5;
    }

    #loading-msg {
      font-size: 13px;
      color: #94a3b8;
      display: none;
    }
  </style>
</head>
<body>

  <!-- The card that gets captured -->
  <div id="story-card">
    <img
      class="card-photo"
      src={driver.image}
      alt={driver.name}
      crossorigin="anonymous"
    />
    <div class="card-photo-fade"></div>

    <div class="card-content">
      <div class="card-name-row">
        <div>
          <div class="card-name">{driver.name}</div>
          <div class="card-specialty">{driver.specialty}</div>
        </div>
        <div class="card-rating-pill">
          <span class="card-rating-num">{driver.rating}</span>
          <span class="card-rating-stars">{stars}</span>
        </div>
      </div>

      <div class="card-badges">
        <span class="badge-verified">✓ PVC Verified</span>
        {driver.trips && <span class="badge-trips">{driver.trips} Trips</span>}
      </div>

      <div class="card-stats">
        <div class="card-stat"><span class="card-dot"></span>{driver.experience}</div>
        <div class="card-stat"><span class="card-dot"></span>{driver.languages}</div>
        <div class="card-stat"><span class="card-dot"></span>{driver.reviews} verified reviews</div>
      </div>

      <div class="card-footer">
        <div class="card-brand">KALIDASS TRAVELS</div>
        <div class="card-contact">+91 90923 03060  •  kalidasstravels.in</div>
      </div>
    </div>
  </div>

  <!-- Actions -->
  <div class="actions">
    <button class="btn-download" id="download-btn" onclick="downloadCard()">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Save Story Card
    </button>

    <div id="loading-msg">Generating image, please wait…</div>

    <a class="btn-whatsapp" href={`https://wa.me/${phone}?text=${waBookText}`} target="_blank" rel="noopener noreferrer">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      Book on WhatsApp
    </a>

    <p class="hint">Save the card → open WhatsApp → Status → add to your status</p>

    <a class="btn-back" href={`/drivers/${Astro.params.slug}`}>← Back to profile</a>
  </div>

  <!-- html2canvas from CDN — no npm install needed -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js" crossorigin="anonymous"></script>

  <script is:inline define:vars={{ driverName: driver.name }}>
    async function downloadCard() {
      const btn = document.getElementById('download-btn');
      const msg = document.getElementById('loading-msg');
      const card = document.getElementById('story-card');

      btn.disabled = true;
      btn.textContent = 'Generating…';
      msg.style.display = 'block';

      try {
        // Render at 3× for crisp quality on any screen
        const canvas = await html2canvas(card, {
          scale: 3,
          useCORS: true,
          allowTaint: false,
          backgroundColor: '#0f172a',
          logging: false,
        });

        const fileName = driverName.replace(/\s+/g, '-') + '-Kalidass-Travels.png';

        // Web Share API — lets user share directly to WhatsApp on mobile
        if (navigator.canShare) {
          try {
            const blob = await new Promise((resolve) => canvas.toBlob(resolve, 'image/png'));
            const file = new File([blob], fileName, { type: 'image/png' });
            if (navigator.canShare({ files: [file] })) {
              await navigator.share({ files: [file], title: driverName + ' – Kalidass Travels' });
              return;
            }
          } catch (e) {
            // Share cancelled or not supported, fall through to download
          }
        }

        // Fallback: direct download
        const link = document.createElement('a');
        link.download = fileName;
        link.href = canvas.toDataURL('image/png');
        link.click();
      } catch (err) {
        alert('Could not generate image. Please take a screenshot instead.');
        console.error(err);
      } finally {
        btn.disabled = false;
        btn.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg> Save Story Card`;
        msg.style.display = 'none';
      }
    }
  </script>

</body>
</html>
