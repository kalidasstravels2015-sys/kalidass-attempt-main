---
const { lang = "en" } = Astro.props;
const isTamil = lang === "ta";

import OptimizedImage from "./OptimizedImage.astro";
import serviceDetails from "../data/serviceDetails.json";

// 1. Temple Trips (Strictly religious/pilgrimage)
const templeTripsSlugs = [
  "sabarimala-trip",
  "thiruvannamalai-girivalam-trip",
  "tirupati-package",
  "rameswaram-2-days",
  "chidambaram-temple-trip",
  "navagraha-tour",
];

const templeTrips = serviceDetails.filter((service) =>
  templeTripsSlugs.includes(service.slug),
);

// 2. Popular Destinations (Leisure, Heritage, City)
const destinationSlugs = [
  "pondicherry-one-day-trip",
  "mahabalipuram-ecr-temple-route",
  "one-day-chennai-city-tour",
];

const popularDestinations = serviceDetails.filter((service) =>
  destinationSlugs.includes(service.slug),
);

// Image Mapping
const tourImages: Record<string, string> = {
  "tirupati-package": "/images/temple/Tirupati-Balaji.jpg",
  "thiruvannamalai-girivalam-trip":
    "/images/temple/Thiruvannamalai-Girivalam.jpg",
  "rameswaram-2-days": "/images/temple/Rameswaram.jpg",
  "navagraha-tour": "/images/temple/Navagraha.jpg",
  "kanchipuram-temple-trip": "/images/temple/Kanchipuram-Temple.jpg",
  "chidambaram-temple-trip": "/images/temple/Chidambaram-Natarajar-Temple.jpg",
  "sabarimala-trip": "/images/temple/Sabarimala-Temple.jpg",
  "pondicherry-one-day-trip": "/images/temple/pondicherry.webp",
  "vellore-golden-temple": "/images/temple/Vellore-Golden.jpg",
  "mahabalipuram-ecr-temple-route":
    "/images/temple/Mahabalipuram-ECR-Temples.jpg",
  "one-day-chennai-city-tour": "/images/temple/chennai-city.jpg",
};

const tourImageAlts: Record<string, string> = {
  "tirupati-package":
    "Tirupati Balaji Temple darshan package with taxi service from Chennai",
  "thiruvannamalai-girivalam-trip":
    "Thiruvannamalai Girivalam full moon day trip from Chennai",
  "rameswaram-2-days":
    "Rameswaram 2-day pilgrimage tour including Dhanushkodi beach",
  "navagraha-tour": "Complete Navagraha temple tour package Kumbakonam taxi",
  "chidambaram-temple-trip":
    "Chidambaram Nataraja Temple spiritual visit taxi service",
  "sabarimala-trip":
    "Sabarimala Mandala Pooja pilgrimage taxi package from Chennai",
  "pondicherry-one-day-trip":
    "Pondicherry one day sightseeing trip from Chennai by car",
  "mahabalipuram-ecr-temple-route":
    "Mahabalipuram and ECR temple heritage tour taxi",
  "one-day-chennai-city-tour":
    "Chennai local city sightseeing day tour cab service",
};
---

<section id="tours" class="py-10 md:py-16 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4">
    <!-- SECTION 1: POPULAR TEMPLE TRIPS -->
    <div class="mb-12">
      <div class="text-center mb-8">
        <h2
          class="text-2xl md:text-4xl font-extrabold text-gray-900 inline-block relative mb-3"
        >
          {isTamil ? "பிரபலமான கோவில் சுற்றுலா" : "Popular Temple Trips"}
          <div
            class="absolute bottom-[-8px] left-1/2 transform -translate-x-1/2 w-16 h-1 bg-orange-600 rounded-full"
          >
          </div>
        </h2>
        <p class="text-base text-gray-600 max-w-2xl mx-auto mt-2">
          {
            isTamil
              ? "புனித யாத்திரைகள் மற்றும் ஆன்மீக பயணங்கள்."
              : "Sacred pilgrimages and spiritual journeys."
          }
        </p>
      </div>

      <div class="flex overflow-x-auto gap-4 px-2 pb-6 scrollbar-hide snap-x">
        {
          templeTrips.map((tour) => {
            const link = isTamil
              ? `/ta/services/${tour.slug}/`
              : `/services/${tour.slug}/`;
            return (
              <a
                href={link}
                class="block flex-none w-64 sm:w-72 snap-center bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden group cursor-pointer hover:shadow-md transition"
              >
                <div class="h-36 sm:h-40 overflow-hidden relative bg-gray-200 skeleton-shimmer">
                  <OptimizedImage
                    src={
                      tourImages[tour.slug] ||
                      "https://images.unsplash.com/photo-1596700414605-e45f1b1c7c9a?q=80&w=600"
                    }
                    alt={
                      tourImageAlts[tour.slug] ||
                      (isTamil ? tour.title_ta : tour.title)
                    }
                    class="w-full h-full object-cover group-hover:scale-105 transition duration-700 relative z-10"
                    sizes="288px"
                  />
                  <span class="absolute top-2 left-2 bg-orange-800 text-white text-[10px] font-bold px-2 py-0.5 rounded shadow-sm">
                    {isTamil ? "யாத்திரை" : "PILGRIMAGE"}
                  </span>
                </div>
                <div class="p-4">
                  <h3 class="font-bold text-base text-gray-900 mb-1 line-clamp-1">
                    {isTamil ? tour.title_ta : tour.title}
                  </h3>
                  <p class="text-xs text-gray-600 mb-3 line-clamp-2">
                    {isTamil ? tour.overview_ta : tour.overview}
                  </p>
                  <div class="flex items-center text-orange-800 font-bold text-xs uppercase tracking-wide group-hover:text-orange-900">
                    <span>
                      {isTamil
                        ? `${tour.title_ta} முன்பதிவு`
                        : `Book ${tour.title}`}
                    </span>
                    <i class="fas fa-arrow-right ml-1 group-hover:translate-x-1 transition" />
                  </div>
                </div>
              </a>
            );
          })
        }
      </div>
      <div class="text-center mt-4">
        <a
          href={isTamil
            ? "/ta/services/category/temple-tours/"
            : "/services/category/temple-tours/"}
          class="inline-flex items-center text-orange-800 font-bold text-sm hover:text-orange-900 transition"
        >
          {isTamil ? "அனைத்தையும் காண்க" : "View All"}
          <i class="fas fa-arrow-right ml-2"></i>
        </a>
      </div>
    </div>

    <!-- SECTION 2: POPULAR DESTINATIONS -->
    <div>
      <div class="text-center mb-8">
        <h2
          class="text-2xl md:text-4xl font-extrabold text-gray-900 inline-block relative mb-3"
        >
          {isTamil ? "பிரபலமான இடங்கள்" : "Popular Destinations"}
          <div
            class="absolute bottom-[-8px] left-1/2 transform -translate-x-1/2 w-16 h-1 bg-green-600 rounded-full"
          >
          </div>
        </h2>
        <p class="text-base text-gray-600 max-w-2xl mx-auto mt-2">
          {
            isTamil
              ? "பாரம்பரிய இடங்கள், கடற்கரைகள் மற்றும் நகர சுற்றுலா."
              : "Explore heritage sites, beaches, and city tours."
          }
        </p>
      </div>

      <div class="flex overflow-x-auto gap-4 px-2 pb-6 scrollbar-hide snap-x">
        {
          popularDestinations.map((tour) => {
            const link = isTamil
              ? `/ta/services/${tour.slug}/`
              : `/services/${tour.slug}/`;
            return (
              <a
                href={link}
                class="block flex-none w-64 sm:w-72 snap-center bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden group cursor-pointer hover:shadow-md transition"
              >
                <div class="h-36 sm:h-40 overflow-hidden relative bg-gray-200 skeleton-shimmer">
                  <OptimizedImage
                    src={
                      tourImages[tour.slug] ||
                      "https://images.unsplash.com/photo-1596700414605-e45f1b1c7c9a?q=80&w=600"
                    }
                    alt={
                      tourImageAlts[tour.slug] ||
                      (isTamil ? tour.title_ta : tour.title)
                    }
                    class="w-full h-full object-cover group-hover:scale-105 transition duration-700 relative z-10"
                    sizes="288px"
                  />
                  <span class="absolute top-2 left-2 bg-green-800 text-white text-[10px] font-bold px-2 py-0.5 rounded shadow-sm">
                    {isTamil ? "சுற்றுலா தலம்" : "DESTINATION"}
                  </span>
                </div>
                <div class="p-4">
                  <h3 class="font-bold text-base text-gray-900 mb-1 line-clamp-1">
                    {isTamil ? tour.title_ta : tour.title}
                  </h3>
                  <p class="text-xs text-gray-600 mb-3 line-clamp-2">
                    {isTamil ? tour.overview_ta : tour.overview}
                  </p>
                  <div class="flex items-center text-green-800 font-bold text-xs uppercase tracking-wide group-hover:text-green-900">
                    <span>
                      {isTamil
                        ? `${tour.title_ta} சுற்றுலா`
                        : `Explore ${tour.title}`}
                    </span>
                    <i class="fas fa-arrow-right ml-1 group-hover:translate-x-1 transition" />
                  </div>
                </div>
              </a>
            );
          })
        }
      </div>
      <div class="text-center mt-6">
        <a
          href={isTamil
            ? "/ta/services/category/popular-destinations/"
            : "/services/category/popular-destinations/"}
          class="inline-flex items-center text-green-800 font-bold text-sm hover:text-green-900 transition"
        >
          {isTamil ? "அனைத்தையும் காண்க" : "View All"}
          <i class="fas fa-arrow-right ml-2"></i>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>
